# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Runner ─────────────────────────────────────────────────────────────────
# Shared secret that the judge UI sends as X-Runner-Token.
# Use any string you like. Leave blank to disable auth (dev only).
RUNNER_TOKEN=dev-secret

# Comma-separated origins allowed to call the runner from a browser.
# Localhost is always allowed automatically.
# Add your GitHub Pages URL here once deployed.
ALLOWED_ORIGINS=https://<youruser>.github.io

# Port the runner listens on (default: 8787)
# PORT=8787

# ── Anthropic (required for real Claude-powered agent turns) ────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── GIPHY (optional — enables GIF replies, 100 calls/hour per key) ──────────
GIPHY_API_KEY=your-giphy-api-key-here

# ── Judge UI (baked in at Next.js build time) ───────────────────────────────
# Set these before running `npm run dev:judge` or deploying to GitHub Pages.
NEXT_PUBLIC_RUNNER_URL=http://localhost:8787
NEXT_PUBLIC_RUNNER_TOKEN=dev-secret
NEXT_PUBLIC_BASE_PATH=
